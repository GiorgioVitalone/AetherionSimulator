{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(turbo *)",
      "Bash(git *)"
    ],
    "deny": [
      "Edit(*.env*)",
      "Write(*.env*)",
      "Bash(rm -rf *)",
      "Bash(del /s *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const p=(j.tool_input&&(j.tool_input.file_path||j.tool_input.filePath))||'';if(p.includes('.env')){console.log('BLOCKED: Cannot edit .env files — secrets must stay out of version control');process.exit(2)}})\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const p=(j.tool_input&&(j.tool_input.file_path||j.tool_input.filePath))||'';if(/\\\\.(tsx?|jsx?|json|css)$/.test(p)&&!p.includes('node_modules')){require('child_process').execSync('npx prettier --write \\\"'+p.replace(/\\\\\\\\/g,'/')+'\\\"',{stdio:'ignore'})}})\""
          }
        ]
      }
    ]
  }
}
