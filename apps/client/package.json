{
  "name": "@aetherion-sim/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src/",
    "e2e:install": "playwright install chromium",
    "e2e:up": "docker compose -f ../../docker-compose.yml up -d --build simulator",
    "e2e:test": "playwright test",
    "e2e:down": "docker compose -f ../../docker-compose.yml down",
    "e2e": "node ./e2e/run-e2e.mjs"
  },
  "dependencies": {
    "@aetherion-sim/engine": "workspace:*",
    "@aetherion-sim/cards": "workspace:*",
    "@aetherion-sim/ui": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.0",
    "xstate": "^5.19.0",
    "immer": "^10.1.0",
    "motion": "^12.12.0"
  },
  "devDependencies": {
    "@aetherion-sim/config": "workspace:*",
    "@vitejs/plugin-react": "^4.5.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@playwright/test": "^1.53.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "vite": "^6.3.0",
    "typescript-eslint": "^8.33.0",
    "eslint": "^9.28.0",
    "jsdom": "^26.1.0"
  }
}
